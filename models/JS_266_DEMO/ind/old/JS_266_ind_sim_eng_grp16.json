{
"connectivity":{
	"notes": "This is for accessing the data",
	"nats": {
		"server": "localhost",
		"port": 4222
    },
    "hsl": {
        "server": "to be defined",
        "port": 8080
    }
},

"input_streams":{
    "sig_inputs": {
        "connection": "nats",
        "type": "groups",
        "subtype": "sumo",
        "nats_subject": "group.status.266.*",
        "notes": "Will subscribe to all groups sent by sumo"
    },
    "det_inputs": {
        "connection": "nats",
        "type": "detectors",
        "subtype": "sumo",
        "nats_subject": "detector.status.*",
        "notes": "Will subscribe to all detectors sent by sumo"
        },
    
    "radar266.10": {
        "connection": "nats",        
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.10.objects_port.json",
        "notes": "Michaels sim data for grp16 "
        }
 },

"detlogics":{
    "tram9_request_detlogic":{
        "type": "two_det_switch",
        "notes": "One detector swithces the request on, another off",
        "detectors": {
            "request": "R8PY",
            "clear": "R8KU"
        },
        "request_trigger": "rising_edge",
        "clear_trigger": "falling_edge"
        }
    },

"inputs":{
    "dets":{
        "266_1118A": {
            "type": "rising_edge",
            "stream": "det_inputs",
            "name": "266_1118A"
        },
        "266_1118B": {
            "type": "rising_edge",
            "stream": "det_inputs",
            "name": "266_1118B"
        },
        "266_1102A": {
            "type": "falling_edge",
            "stream": "det_inputs",
            "name": "266_1102A"
        },
        "266_1102B": {
            "type": "falling_edge",
            "stream": "det_inputs",
            "name": "266_1102B"
        }
    },

    "object_filters":{
        "266_2_0": {
            "type": "simple",
            "stream": "radar266.10",
            "lane": "0"
        },
        "266_2_1": {
            "type": "simple",
            "stream": "radar266.10",
            "lane": "1"
        }          
    },

    "groups": {
        "group16": {
            "type": "simple",
            "stream": "sig_inputs",
            "group": "16"
        }
    }

},

"lanes":{
 
    "grp16_0":{
        "name": "Group 16 ped lane 0 south",
        "object_lists":["266_2_0"], 
        "notes": "Bikes from south"
    },
    "grp16_1":{
        "name": "Group 16 ped lane 1 north",
        "object_lists":["266_2_1"], 
        "notes": "Bikes from North"
    }

},

"outputs":{

    "group16_view":{
        "connection": "nats",
        "type": "e3",
        "nats_output_subject": "group.e3.266.16",
        "trigger": "time",
        "trigger_time": 1.0,
        "lanes": ["grp16_0","grp16_1"],
        "group": "group16",
        "notes": "From Mech South to Ped Grp 16"
        }

    }
}