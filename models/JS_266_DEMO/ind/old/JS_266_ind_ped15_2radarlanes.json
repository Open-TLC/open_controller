{
"connectivity":{
	"notes": "This is for accessing the data",
	"nats": {
		"server": "localhost",
		"port": 4222
    },
    "hsl": {
        "server": "to be defined",
        "port": 8080
    }
},

"input_streams":{
    "sig_inputs": {
        "connection": "nats",
        "type": "groups",
        "subtype": "sumo",
        "nats_subject": "group.status.266.*",
        "notes": "Will subscribe to all groups sent by sumo"
    },
    "det_inputs": {
        "connection": "nats",
        "type": "detectors",
        "subtype": "sumo",
        "nats_subject": "detector.status.*",
        "notes": "Will subscribe to all detectors sent by sumo"
        },
    "radar266.1": {
        "connection": "nats",
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.1.objects_port.json",
        "notes": "Will subscribe to radar pointing north"
        },
    "radar266.2": {
        "connection": "nats",        
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.2.objects_port.json",
        "notes": "Will subscribe to radar pointing west (arriving)"
        },
    "radar266.3": {
        "connection": "nats",
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.3.objects_port.json",
        "notes": "Will subscribe to radar pointing west (departing)"
        },

    "radar266.4": {
        "connection": "nats",
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.4.objects_port.json",
        "notes": "Will subscribe to radar 266 north south in middle"
        },
    "radar266.5": {
        "connection": "nats",
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.5.objects_port.json",
        "notes": "Will subscribe to radar 266 south"
        },
    "radar266.7": {
        "connection": "nats",
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.7.objects_port.json",
        "notes": "Will subscribe to radar 266 south pedestrian"
        },
     "radar266.8": {
        "connection": "nats",
        "type": "radar",
        "subtype": "sumo",
        "nats_subject": "radar.266.8.objects_port.json",
        "notes": "Will subscribe to radar 266 north pedestrian"
        }
    },

"detlogics":{
    "tram9_request_detlogic":{
        "type": "two_det_switch",
        "notes": "One detector swithces the request on, another off",
        "detectors": {
            "request": "R8PY",
            "clear": "R8KU"
        },
        "request_trigger": "rising_edge",
        "clear_trigger": "falling_edge"
        }
    },

"inputs":{
    "dets":{
        "266_1118A": {
            "type": "rising_edge",
            "stream": "det_inputs",
            "name": "266_1118A"
        },
        "266_1118B": {
            "type": "rising_edge",
            "stream": "det_inputs",
            "name": "266_1118B"
        },
        "266_1102A": {
            "type": "falling_edge",
